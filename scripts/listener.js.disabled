const { spawn, exec } = require('child_process');
const fs = require('fs');
const fsPromises = fs.promises;
const path = require('path');
const util = require('util');
const execAsync = util.promisify(exec);
const { addMessage, formatHistoryForPrompt, trackConsumption } = require('/home/ubuntu/.gemini/skills/common/history');
const { transcribeAudio } = require('/home/ubuntu/scripts/transcribe');
const { decryptThreemaVoice } = require('/home/ubuntu/scripts/threema_file_helper');
require('dotenv').config({ path: path.join(__dirname, '../.env') });

const THREEMA_ID = process.env.THREEMA_ID;
const BRIDGE_PATH = path.join(__dirname, '../rust-bridge/target/release/threema-gemini-bridge');
const LOG_FILE = '/home/ubuntu/threema-listener.log';
const GEMINI_TIMEOUT = 86400000;

function log(msg) {
    const timestamp = new Date().toISOString();
    const line = `[${timestamp}] ${msg}\n`;
    fs.appendFileSync(LOG_FILE, line);
    console.log(`[Threema] ${msg}`);
}

function cleanGeminiOutput(text) {
    let cleaned = text;
    cleaned = cleaned.replace(/<thinking>[\s\S]*?<\/thinking>/g, '');
    cleaned = cleaned.replace(/<function_calls>[\s\S]*?<\/function_calls>/g, '');
    cleaned = cleaned.replace(/<function_outputs>[\s\S]*?<\/function_outputs>/g, '');
    cleaned = cleaned.replace(/<tool_calls>[\s\S]*?<\/tool_calls>/g, '');
    cleaned = cleaned.replace(/```[\s\S]*?```/g, '');
    cleaned = cleaned.split('\n')
        .filter(line => !line.trim().startsWith('I will now') && !line.trim().startsWith('I am now') && !line.trim().startsWith('Ich werde nun'))
        .join('\n');
    return cleaned.trim();
}

const taskQueue = [];
let activeTasks = 0;
const MAX_CONCURRENCY = 3;

async function processQueue() {
    if (activeTasks >= MAX_CONCURRENCY || taskQueue.length === 0) return;
    activeTasks++;
    const task = taskQueue.shift();
    try { await task(); } catch (e) { log(`Task error: ${e.message}`); }
    finally { activeTasks--; processQueue(); }
}

function enqueueTask(task) {
    taskQueue.push(task);
    processQueue();
}

log(`Starting Threema Listener for ${THREEMA_ID}...`);
const bridge = spawn(BRIDGE_PATH, [
    '--threema-id', THREEMA_ID, 
    '--client-key', process.env.THREEMA_CLIENT_KEY, 
    '--csp-server-group', '0',
    '--consumer', 'production'
], {
    env: process.env
});

bridge.stdout.on('data', async (data) => {
    const lines = data.toString().split('\n');
    for (const line of lines) {
        const trimmedLine = line.trim();
        if (!trimmedLine) continue;

        if (trimmedLine.startsWith('BRIDGE-JSON: ')) {
            const jsonPart = trimmedLine.substring('BRIDGE-JSON: '.length);
            try {
                const msg = JSON.parse(jsonPart);
                if (msg.type === 'Message') {
                    await handleMessage(msg);
                } else if (msg.type === 'Unknown') {
                    log(`[DEBUG] Unknown message type ${msg.message_type} from ${msg.sender}`);
                    if (msg.message_type === 23) { // Voice
                        if (msg.sender.startsWith('*')) {
                            log(`[INFO] Processing Group Voice Message from ${msg.sender}`);
                            try {
                                const decryptedPath = await decryptThreemaVoice(msg.data_hex, msg.sender);
                                if (decryptedPath) {
                                    const transcript = await transcribeAudio(decryptedPath);
                                    if (transcript) {
                                        const header = `Transkription der Sprachnachricht von @${msg.sender}:`;
                                        bridge.stdin.write(JSON.stringify({ type: 'SendMessage', recipient: msg.sender, text: `${header}\n\n${transcript}` }) + '\n');
                                    }
                                    if (fs.existsSync(decryptedPath)) fs.unlinkSync(decryptedPath);
                                }
                            } catch (e) { log(`Voice error: ${e.message}`); }
                        }
                    }
                } else if (msg.type === 'HandshakeComplete') {
                    log('Connected to Threema server.');
                    if (process.env.STEPHAN_THREEMA_ID) {
                        bridge.stdin.write(JSON.stringify({ type: 'SendMessage', recipient: process.env.STEPHAN_THREEMA_ID, text: "🔄 Threema Online." }) + '\n');
                    }
                }
            } catch (e) { log(`JSON Error: ${e.message} | Line: ${jsonPart}`); }
        } else {
            log(`Bridge: ${trimmedLine}`);
        }
    }
});

bridge.stderr.on('data', (data) => log(`Bridge Stderr: ${data.toString()}`));
bridge.on('close', (code) => { log(`Bridge exited: ${code}`); process.exit(code); });

async function handleMessage(msg) {
    const senderId = msg.sender;
    if (senderId === THREEMA_ID) return;

    log(`Message from ${senderId}: ${msg.text}`);
    
    await addMessage(senderId, 'threema', 'User', msg.text);
    const history = await formatHistoryForPrompt(senderId, 'threema');
    const fullQuery = `Follow instructions. Threema context. ${history}\n\nUser: ${msg.text}`;

    enqueueTask(async () => {
        try {
            const { execFile } = require('child_process');
            const execFileAsync = util.promisify(execFile);
            const approvalMode = (senderId === process.env.STEPHAN_THREEMA_ID) ? 'yolo' : 'plan';
            
            const { stdout } = await execFileAsync('/home/ubuntu/gemini-wrapper.js', ['--approval-mode', approvalMode, '-p', fullQuery], { 
                env: { ...process.env, LANG: 'en_US.UTF-8' }, timeout: GEMINI_TIMEOUT 
            });

            let response = cleanGeminiOutput(stdout) || "*(Erledigt)*";
            await trackConsumption('threema', fullQuery.length, response.length);
            await addMessage(senderId, 'threema', 'Assistant', response);
            bridge.stdin.write(JSON.stringify({ type: 'SendMessage', recipient: senderId, text: response }) + '\n');
        } catch (error) { log(`Gemini Error: ${error.message}`); }
    });
}
